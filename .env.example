NODE_ENV=development
PORT=3000

# Local (Docker)
MONGODB_URI=mongodb://localhost:27017/bizopd
REDIS_URL=redis://localhost:6379

# Production (Render) — use cloud services, NOT localhost
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bizopd?retryWrites=true&w=majority
# REDIS_URL=rediss://<user>:<password>@<host>:<port>

CORS_ORIGIN=*

# Security
TRUST_PROXY=false
ENABLE_HTTPS_REDIRECT=false
ENABLE_REQUEST_LOGGING=true
ENABLE_COMPRESSION=true
ENABLE_DEBUG_REQUEST_LOG=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
BODY_LIMIT=10kb
